{
  "name": "lb-ereader",
  "version": "0.1.0",
  "description": "LB-EReader Cordova ebook reader with OnsenUI, jQuery and epub.js.",
  "private": true,
  "scripts": {
    "prepare:android": "cordova prepare android",
    "prepare:browser": "cordova prepare browser",
    "build:android": "cordova build android",
    "run:android": "cordova run android",
    "run:browser": "cordova run browser",
    "run:browser:live": "cordova run browser -- --live-reload",
    "serve": "cordova serve"
  },
  "dependencies": {
    "cordova-android": "^14.0.1",
    "cordova-plugin-console": "^1.0.5",
    "cordova-plugin-device": "^1.1.4",
    "cordova-plugin-music-controls2": "^3.0.6",
    "cordova-plugin-splashscreen": "^4.0.3",
    "cordova-plugin-statusbar": "^2.2.2",
    "cordova-plugin-webview-mixed-content": "file:plugins-local/cordova-plugin-webview-mixed-content",
    "cordova-sqlite-storage": "7.0.0",
    "jszip": "^3.10.1"
  },
  "devDependencies": {
    "cordova": "^12.0.0",
    "cordova-browser": "^7.0.0",
    "cordova-plugin-browsersync-gen2": "^1.1.7"
  },
  "cordova": {
    "plugins": {
      "cordova-plugin-console": {},
      "cordova-plugin-device": {},
      "cordova-plugin-music-controls2": {},
      "cordova-plugin-splashscreen": {},
      "cordova-plugin-statusbar": {},
      "cordova-sqlite-storage": {},
      "cordova-plugin-webview-mixed-content": {},
      "cordova-plugin-browsersync-gen2": {}
    },
    "platforms": [
      "android",
      "browser"
    ]
  }
}
