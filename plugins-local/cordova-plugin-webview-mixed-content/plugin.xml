<?xml version="1.0" encoding="UTF-8"?>
<plugin id="cordova-plugin-webview-mixed-content" version="0.1.0" xmlns="http://apache.org/cordova/ns/plugins/1.0">
    <name>WebView Mixed Content</name>
    <description>Allow the Android Cordova WebView to call HTTP services from the HTTPS localhost app origin.</description>
    <license>MIT</license>

    <platform name="android">
        <config-file target="res/xml/config.xml" parent="/*">
            <feature name="WebViewMixedContent">
                <param name="android-package" value="de.janpiotrowski.ionic.epubjs.plugins.WebViewMixedContent" />
                <param name="onload" value="true" />
            </feature>
        </config-file>

        <js-module src="www/native-http.js" name="NativeHttp">
            <clobbers target="NativeHttp" />
        </js-module>

        <source-file src="src/android/WebViewMixedContent.java" target-dir="src/de/janpiotrowski/ionic/epubjs/plugins" />
    </platform>
</plugin>
